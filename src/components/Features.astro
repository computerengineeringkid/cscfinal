---
/**
 * Features.astro
 * 2x2 grid of feature cards highlighting what Strafe Inbox AI does. Each card
 * has a gradient SVG icon, name, and a two-sentence description.
 *
 * @author Claude AI — built the 2x2 grid, four feature cards with inline SVG
 * icons, gradient hover-border effect, and the section header.
 */

const features = [
  {
    name: 'AI Email Classification',
    description:
      'Every incoming email is analyzed by AI in real-time. It reads the content, subject, and sender to determine exactly what type of email it is.',
    icon: 'brain',
  },
  {
    name: 'Smart Routing',
    description:
      'Support requests get posted to Slack instantly with full context. Transactional emails are filtered out so your team only sees what matters.',
    icon: 'route',
  },
  {
    name: 'Error Handling',
    description:
      'If the AI classification fails, your team gets an immediate Slack DM alert. Nothing gets lost, nothing gets missed.',
    icon: 'shield',
  },
  {
    name: 'Thread Tracking',
    description:
      'Every conversation is tracked and saved with thread mapping. Follow-ups get linked to original tickets automatically.',
    icon: 'thread',
  },
];
---

<section class="section features" id="features">
  <div class="container-pad">
    <header class="section-head reveal">
      <span class="eyebrow">Features</span>
      <h2 class="section-title">What Strafe Inbox AI Does</h2>
      <p class="section-sub">Four building blocks that turn your inbox from a backlog into a routed, prioritized stream.</p>
    </header>

    <div class="feature-grid stagger">
      {features.map((f) => (
        <article class="feature-card">
          <div class="feature-icon" aria-hidden="true">
            {f.icon === 'brain' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M8 4a3 3 0 0 0-3 3v1a3 3 0 0 0-2 2.8A3 3 0 0 0 5 14a3 3 0 0 0 3 3v1a3 3 0 0 0 4 0v-1a3 3 0 0 0 3-3 3 3 0 0 0 2-3.2A3 3 0 0 0 15 8V7a3 3 0 0 0-3-3 3 3 0 0 0-4 0Z"/>
                <path d="M12 4v16M9 9h.01M15 9h.01"/>
              </svg>
            )}
            {f.icon === 'route' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <circle cx="6" cy="19" r="3"/><circle cx="18" cy="5" r="3"/>
                <path d="M6 16V9a4 4 0 0 1 4-4h4M14 19h4a4 4 0 0 0 4-4v-2"/>
              </svg>
            )}
            {f.icon === 'shield' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M12 3 4 6v6c0 5 3.5 8.5 8 9 4.5-.5 8-4 8-9V6l-8-3Z"/>
                <path d="m9 12 2 2 4-4"/>
              </svg>
            )}
            {f.icon === 'thread' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M21 11.5a8.4 8.4 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.4 8.4 0 0 1-3.8-.9L3 21l1.9-5.7a8.4 8.4 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.4 8.4 0 0 1 3.8-.9h.5a8.5 8.5 0 0 1 8 8v.5Z"/>
              </svg>
            )}
          </div>
          <h3 class="feature-name">{f.name}</h3>
          <p class="feature-desc">{f.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .section-head {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 64px;
  }
  .section-title {
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -1px;
    margin: 16px 0 16px;
    line-height: 1.15;
  }
  .section-sub {
    font-size: 18px;
    color: var(--text-secondary);
    margin: 0 auto;
    max-width: 600px;
  }
  .feature-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .feature-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px;
    transition: transform var(--transition), border-color var(--transition), background var(--transition);
    position: relative;
    overflow: hidden;
  }
  .feature-card::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 16px;
    padding: 1px;
    background: var(--gradient);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    opacity: 0;
    transition: opacity var(--transition);
    pointer-events: none;
  }
  .feature-card:hover {
    transform: translateY(-2px);
    border-color: var(--border-hover);
    background: var(--surface-hover);
  }
  .feature-card:hover::after { opacity: 0.6; }
  .feature-icon {
    width: 48px; height: 48px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    background: var(--gradient);
    color: #fff;
    margin-bottom: 20px;
    box-shadow: 0 4px 16px rgba(168, 85, 247, 0.25);
  }
  .feature-name {
    font-size: 20px;
    font-weight: 700;
    margin: 0 0 10px;
    letter-spacing: -0.3px;
  }
  .feature-desc {
    margin: 0;
    color: var(--text-secondary);
    font-size: 15px;
    line-height: 1.65;
  }
  @media (max-width: 768px) {
    .feature-grid { grid-template-columns: 1fr; }
    .section-title { font-size: 28px; }
    .section-sub { font-size: 16px; }
  }
</style>
