---
/**
 * Hero.astro
 * Top-of-page hero with a gradient headline, supporting copy, two CTAs, and a
 * minimal animated SVG showing emails sorting into category lanes.
 */
---

<section class="hero" id="top">
  <div class="hero-glow" aria-hidden="true"></div>

  <div class="container-pad hero-inner">
    <span class="eyebrow hero-eyebrow">AI-Powered Email Automation</span>

    <h1 class="hero-headline">
      <span class="gradient-text">Your Inbox,</span><br />
      <span class="gradient-text">Intelligently Sorted.</span>
    </h1>

    <p class="hero-sub">
      Strafe Inbox AI uses artificial intelligence to automatically classify, prioritize, and route
      your emails to the right team — in seconds, not hours.
    </p>

    <div class="hero-ctas">
      <a href="#demo" class="btn btn-primary">
        See It In Action
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7" />
        </svg>
      </a>
      <a
        href="https://github.com/strafe-digital/strafe-inbox-ai"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-outline"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.69 1.24 3.34.95.1-.74.4-1.24.72-1.53-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.78 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z" />
        </svg>
        View on GitHub
      </a>
    </div>

    <!-- Email sorting animation -->
    <div class="hero-anim" aria-hidden="true">
      <div class="anim-stack">
        <div class="anim-letter l1">
          <div class="anim-dot"></div>
          <div class="anim-line"></div>
          <div class="anim-line short"></div>
        </div>
        <div class="anim-letter l2">
          <div class="anim-dot"></div>
          <div class="anim-line"></div>
          <div class="anim-line short"></div>
        </div>
        <div class="anim-letter l3">
          <div class="anim-dot"></div>
          <div class="anim-line"></div>
          <div class="anim-line short"></div>
        </div>
      </div>

      <div class="anim-funnel">
        <svg viewBox="0 0 200 80" preserveAspectRatio="none" aria-hidden="true">
          <defs>
            <linearGradient id="funnel-grad" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="#6366f1" stop-opacity="0.6" />
              <stop offset="50%" stop-color="#a855f7" stop-opacity="0.6" />
              <stop offset="100%" stop-color="#ec4899" stop-opacity="0.6" />
            </linearGradient>
          </defs>
          <path d="M10,10 Q100,40 60,70" fill="none" stroke="url(#funnel-grad)" stroke-width="1.2" />
          <path d="M100,10 Q100,40 100,70" fill="none" stroke="url(#funnel-grad)" stroke-width="1.2" />
          <path d="M190,10 Q100,40 140,70" fill="none" stroke="url(#funnel-grad)" stroke-width="1.2" />
        </svg>
      </div>

      <div class="anim-lanes">
        <div class="anim-lane lane-support">
          <span class="lane-label">Support</span>
        </div>
        <div class="anim-lane lane-inquiry">
          <span class="lane-label">Inquiry</span>
        </div>
        <div class="anim-lane lane-archive">
          <span class="lane-label">Archive</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: 160px;
    padding-bottom: 80px;
    overflow: hidden;
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    text-align: center;
  }
  .hero-eyebrow {
    display: inline-block;
    padding: 6px 14px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.02);
    margin-bottom: 32px;
  }
  .hero-headline {
    font-size: 64px;
    font-weight: 800;
    letter-spacing: -2px;
    line-height: 1.1;
    margin: 0 0 24px;
  }
  .hero-sub {
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto 40px;
  }
  .hero-ctas {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 80px;
  }

  /* Email sorting animation */
  .hero-anim {
    display: grid;
    grid-template-columns: 1fr 1.2fr 1fr;
    align-items: center;
    gap: 32px;
    max-width: 720px;
    margin: 0 auto;
    height: 220px;
    position: relative;
  }
  .anim-stack {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .anim-letter {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    animation: float 3.6s ease-in-out infinite;
  }
  .anim-letter.l2 { animation-delay: 0.4s; }
  .anim-letter.l3 { animation-delay: 0.8s; }
  .anim-dot {
    width: 22px; height: 22px; border-radius: 50%;
    background: linear-gradient(135deg, #6366f1, #a855f7);
  }
  .anim-line {
    height: 6px; border-radius: 3px;
    background: rgba(255, 255, 255, 0.08);
    width: 100%;
  }
  .anim-line.short { width: 60%; }
  .anim-funnel { height: 100%; display: flex; align-items: center; }
  .anim-funnel svg { width: 100%; height: 100%; }
  .anim-lanes {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .anim-lane {
    height: 44px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--surface);
    display: flex;
    align-items: center;
    padding-inline: 14px;
    position: relative;
    overflow: hidden;
  }
  .lane-label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--text-secondary);
    z-index: 2;
  }
  .anim-lane::before {
    content: '';
    position: absolute;
    inset: 0;
    transform: translateX(-100%);
    animation: sweep 3.6s ease-in-out infinite;
  }
  .lane-support::before    { background: linear-gradient(90deg, transparent, rgba(34,197,94,0.4), transparent); }
  .lane-inquiry::before    { background: linear-gradient(90deg, transparent, rgba(99,102,241,0.4), transparent); animation-delay: 0.4s; }
  .lane-archive::before    { background: linear-gradient(90deg, transparent, rgba(168,85,247,0.4), transparent); animation-delay: 0.8s; }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-6px); }
  }
  @keyframes sweep {
    0%   { transform: translateX(-100%); }
    50%  { transform: translateX(0); }
    100% { transform: translateX(100%); }
  }

  @media (max-width: 768px) {
    .hero { padding-top: 120px; }
    .hero-headline { font-size: 40px; letter-spacing: -1px; }
    .hero-sub { font-size: 16px; }
    .hero-anim {
      grid-template-columns: 1fr;
      height: auto;
      gap: 16px;
    }
    .anim-funnel { display: none; }
  }
</style>
