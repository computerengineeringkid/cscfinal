---
/**
 * Footer.astro
 * Minimal three-column footer with copyright, an "AI-powered" tagline, and a
 * back-to-top link that anchors to the navbar.
 */

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container-pad footer-inner">
    <div class="footer-cell footer-left">
      <span class="footer-copy">© {year} Strafe Digital</span>
    </div>

    <div class="footer-cell footer-center">
      <span class="footer-power">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="url(#sparkle-grad)" aria-hidden="true">
          <defs>
            <linearGradient id="sparkle-grad" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#6366f1" />
              <stop offset="100%" stop-color="#ec4899" />
            </linearGradient>
          </defs>
          <path d="M12 2l1.8 5.4L19 9l-5.2 1.6L12 16l-1.8-5.4L5 9l5.2-1.6L12 2z" />
        </svg>
        Powered by AI
      </span>
    </div>

    <div class="footer-cell footer-right">
      <a href="#top" class="footer-link">
        Back to top
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M12 19V5M5 12l7-7 7 7"/>
        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding-block: 32px;
    margin-top: 32px;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 24px;
    align-items: center;
  }
  .footer-cell {
    display: flex;
    align-items: center;
  }
  .footer-left { justify-content: flex-start; }
  .footer-center { justify-content: center; }
  .footer-right { justify-content: flex-end; }

  .footer-copy {
    font-size: 13px;
    color: var(--text-secondary);
  }
  .footer-power {
    font-size: 13px;
    color: var(--text-secondary);
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .footer-link {
    font-size: 13px;
    color: var(--text-secondary);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s ease;
  }
  .footer-link:hover {
    color: var(--text-primary);
  }
  @media (max-width: 600px) {
    .footer-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .footer-left, .footer-center, .footer-right { justify-content: center; }
  }
</style>
