---
/**
 * AIEmployees.astro
 * Two-card section crediting the AI tools used to build Strafe Inbox AI.
 * Frames the project as AI-managed development supervised by a human PM.
 *
 * @author Claude AI — built the two credit cards with accent gradient blobs,
 * monogram avatars, and the role/description copy.
 */

const employees = [
  {
    name: 'Claude AI',
    role: 'Lead Developer',
    description:
      'Built the complete landing page, designed the UI architecture, wrote documentation, and assisted with workflow logic and email classification prompts.',
    accent: 'indigo',
    initial: 'C',
  },
  {
    name: 'GitHub Copilot',
    role: 'Code Assistant',
    description:
      'Assisted with code refinement, added comprehensive comments, optimized component structure, and helped build the interactive demo simulation.',
    accent: 'pink',
    initial: 'GH',
  },
];
---

<section class="section employees" id="employees">
  <div class="container-pad">
    <header class="emp-head reveal">
      <span class="eyebrow">The Team</span>
      <h2 class="emp-title">Built by AI, Managed by Me.</h2>
      <p class="emp-sub">
        This project was developed using AI as my development team. As the project manager, I directed two AI employees to build
        and refine every aspect of Strafe Inbox AI.
      </p>
    </header>

    <div class="emp-grid stagger">
      {employees.map((e) => (
        <article class={`emp-card emp-card--${e.accent}`}>
          <div class="emp-avatar mono" aria-hidden="true">{e.initial}</div>
          <h3 class="emp-name">{e.name}</h3>
          <span class="emp-role mono">{e.role}</span>
          <p class="emp-desc">{e.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .emp-head {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 56px;
  }
  .emp-title {
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -1px;
    margin: 16px 0;
  }
  .emp-sub {
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 640px;
    margin: 0 auto;
  }
  .emp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 880px;
    margin: 0 auto;
  }
  .emp-card {
    position: relative;
    padding: 36px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    transition: transform var(--transition), border-color var(--transition);
  }
  .emp-card:hover { transform: translateY(-2px); border-color: var(--border-hover); }
  .emp-card::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 200px; height: 200px;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.4;
    pointer-events: none;
  }
  .emp-card--indigo::before { background: #6366f1; }
  .emp-card--pink::before   { background: #ec4899; }

  .emp-avatar {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    background: var(--gradient);
    color: #fff;
    font-weight: 700;
    font-size: 18px;
    margin-bottom: 18px;
    box-shadow: 0 4px 18px rgba(168,85,247,0.3);
  }
  .emp-name {
    margin: 0 0 4px;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.3px;
  }
  .emp-role {
    display: block;
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 14px;
  }
  .emp-desc {
    margin: 0;
    color: var(--text-secondary);
    font-size: 15px;
    line-height: 1.65;
  }
  @media (max-width: 768px) {
    .emp-grid { grid-template-columns: 1fr; }
    .emp-title { font-size: 28px; }
  }
</style>
